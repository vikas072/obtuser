rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Users Collection
    match /users/{userId} {
      // Users can only read their own document
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      
      // Users can create their own document, but cannot set isPaid or purchasedSemesters initially
      allow create: if request.auth != null && request.auth.uid == userId 
                    && (!request.resource.data.keys().hasAny(['isPaid', 'purchasedSemesters']));
      
      // Users can update their own document, but cannot modify isPaid or purchasedSemesters
      allow update: if request.auth != null && request.auth.uid == userId 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPaid', 'purchasedSemesters']));
    }

    // 2. Content Collection
    match /content/{document=**} {
      // Any authenticated user can read subject metadata (list subjects).
      // Access to actual video/notes is enforced on the frontend (blur + lock for unpaid users).
      allow read: if request.auth != null;
      
      // Nobody can write from the client (backend Admin SDK bypasses this)
      allow write: if false;
    }

    // 3. Transactions Collection
    match /transactions/{transactionId} {
      // Users can only read transactions where the uid matches their own
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      
      // Nobody can write from the client (backend Admin SDK bypasses this)
      allow write: if false;
    }
    
  }
}
